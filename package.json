{
  "name": "feishu-claude-code",
  "version": "1.0.0",
  "description": "Feishu/Lark channel plugin for Claude Code - interact with Claude Code remotely via Feishu",
  "main": "dist/index.js",
  "bin": {
    "feishu-claude-code": "dist/index.js"
  },
  "files": [
    "dist/",
    ".env.example",
    "config.example.json",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "watch": "ts-node-dev --respawn src/index.ts",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@larksuiteoapi/node-sdk": "^1.40.0",
    "dotenv": "^16.4.5",
    "marked": "^12.0.0",
    "winston": "^3.13.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
