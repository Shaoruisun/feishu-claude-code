# ──────────────────────────────────────────────────────────
# 飞书应用凭证（必填）
# 在飞书开放平台 https://open.feishu.cn 创建自建应用后获取
# ──────────────────────────────────────────────────────────
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 飞书域名: feishu（国内）| lark（国际）| 自定义私有部署地址
FEISHU_DOMAIN=feishu

# 可选：消息加密和验证（webhook 模式需要）
# FEISHU_VERIFICATION_TOKEN=your_verification_token
# FEISHU_ENCRYPT_KEY=your_encrypt_key

# ──────────────────────────────────────────────────────────
# Claude Code 配置
# ──────────────────────────────────────────────────────────
# claude CLI 路径，默认为 PATH 中的 claude
CLAUDE_BIN=claude

# Claude 的工作目录（它可以读写的目录）
CLAUDE_WORKDIR=/home/user/projects

# 权限模式（关键配置，远程无终端场景必须设置）:
#   bypassPermissions  自动批准所有操作，无需确认（推荐用于受信任的远程场景）
#   acceptEdits        仅自动批准文件编辑，其他操作仍需确认
#   default            保持交互式确认，需要本地终端才能操作
CLAUDE_PERMISSION_MODE=bypassPermissions

# 会话空闲超时（毫秒），默认 30 分钟
CLAUDE_SESSION_TIMEOUT=1800000

# 最大并发会话数
CLAUDE_MAX_SESSIONS=50

# ──────────────────────────────────────────────────────────
# 机器人行为配置
# ──────────────────────────────────────────────────────────
# 群聊中是否需要 @机器人 才响应，true | false
BOT_REQUIRE_MENTION=true

# 白名单群聊 ID，逗号分隔，为空则允许所有群
# BOT_ALLOWED_GROUP_IDS=oc_xxx,oc_yyy

# 白名单用户 open_id，逗号分隔，为空则允许所有用户
# BOT_ALLOWED_USER_IDS=ou_xxx,ou_yyy

# 飞书卡片更新节流间隔（毫秒），默认 800ms
BOT_STREAMING_INTERVAL=800

# 单条消息最大字符数（超出截断），默认 4000
BOT_MAX_MESSAGE_LENGTH=4000

# 会话隔离粒度: chat（按聊天，群组共享）| user（按用户，互相隔离）
BOT_SESSION_SCOPE=chat

# ──────────────────────────────────────────────────────────
# 日志级别: error | warn | info | debug
# ──────────────────────────────────────────────────────────
LOG_LEVEL=info

# 配置文件路径（可选，优先使用文件配置）
# CONFIG_FILE=config.json
